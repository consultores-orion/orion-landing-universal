{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm start",
      "startServerReadyPattern": "started server on",
      "url": ["http://localhost:3000"],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.5 }],

        "uses-http2": "off",
        "uses-long-cache-ttl": "off",
        "uses-optimized-images": "off",
        "modern-image-formats": "off",

        "is-crawlable": "off",
        "redirects": "off",
        "document-latency-insight": "off",

        "legacy-javascript-insight": "off",

        "render-blocking-resources": ["warn", { "maxLength": 3 }],
        "render-blocking-insight": ["warn", { "maxLength": 3 }],

        "unused-javascript": ["warn", { "maxLength": 5 }],
        "unused-css-rules": ["warn", { "maxLength": 5 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
